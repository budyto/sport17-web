rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Lectura pública: la web sport17.com.ar lista productos y categorías.
    // Escritura: solo administradores autenticados (lista en /admin/firebase-config.js).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'admin@sport17.com.ar'
        ];
    }

    // Productos: público lee, admin escribe
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Categorías: público lee, admin escribe
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Secciones (Hombres, Mujeres, Tecnología, etc.): nivel padre de categorías.
    // Público lee para renderizar la home, admin escribe para crear/editar.
    match /sections/{sectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Configuración global de la tienda (textos del hero, redes, etc.)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Logs / actividad (solo admin)
    match /activity/{document=**} {
      allow read, write: if isAdmin();
    }

    // Historial de imports (snapshots para deshacer). Solo admin.
    match /import-history/{document=**} {
      allow read, write: if isAdmin();
    }

    // Newsletter: cualquiera puede SUMARSE (create) con un email valido y
    // datos minimos. Solo admin puede leer / borrar.
    match /newsletter/{document} {
      allow read, delete: if isAdmin();
      allow create: if request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.email.size() < 200
        && request.resource.data.keys().hasOnly(['email', 'source', 'createdAt']);
      allow update: if false;
    }
  }
}
